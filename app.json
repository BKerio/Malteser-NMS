{
  "expo": {
    "name": "NMS Responder",
    "slug": "nms-responder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nms-responder",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.nms.responder",
      "infoPlist": {
        "NSCameraUsageDescription": "Take a check-in selfie to start your shift.",
        "NSLocationWhenInUseUsageDescription": "Record where you checked in and share your ambulance location with dispatch during active assignments.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NMS shares your ambulance location with dispatch during active assignments."
      }
    },
    "android": {
      "package": "com.nms.responder",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "INTERNET"
      ],
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#005A32",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#005A32",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Record where you checked in and share your ambulance location with dispatch during active assignments."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Take a check-in selfie to start your shift."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    }
  }
}